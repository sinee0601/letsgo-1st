-- 7. 일정 게시물 (SCHEDULE_POST)
-- 커뮤니티에 공유된 다른 사람들의 여행 일정입니다.
CREATE SEQUENCE SEQ_SCHEDULE_POST;
DROP SEQUENCE SEQ_SCHEDULE_POST;

CREATE TABLE SCHEDULE_POST (
    POST_ID           VARCHAR2(20)  NOT NULL, -- [PK] 게시물 고유 아이디
    TITLE             VARCHAR2(200) NOT NULL, -- 게시물 제목
    LIKE_COUNT        NUMBER(20)    DEFAULT 0,-- 게시물 추천 수
    VIEW_COUNT        NUMBER(20)   DEFAULT 0,-- 게시물 조회 수
    BUDGET_DETAILS    VARCHAR2(200),          -- 여행 총 예산 메모
    TODO_DETAILS      VARCHAR2(200),          -- 여행 전 할 일 메모    
    POSTED_AT         DATE          NOT NULL, -- 게시일
    IS_ANONYMOUS      NUMBER(1)     NOT NULL, -- 익명 게시 여부
    USER_ID           VARCHAR2(20)  NOT NULL, -- [FK] 게시물 작성자
    CONSTRAINT PK_POST PRIMARY KEY (POST_ID),
    CONSTRAINT FK_POST_USER FOREIGN KEY (USER_ID) REFERENCES USERS(USER_ID)
);
DROP TABLE SCHEDULE_POST

