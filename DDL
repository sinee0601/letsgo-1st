CREATE TABLE VISIT_ITEM (
    VISIT_ITEM_ID     NUMBER(20)    NOT NULL, -- [PK] 방문지 항목 아이디
    VISIT_ORDER       NUMBER(10)    NOT NULL, -- 해당 일정 내 방문 순서 (1, 2, 3...)
    DISTANCE_TO_NEXT  NUMBER(20),                 -- 다음 목적지까지의 거리(km 등)
    PLACE_ID          VARCHAR2(20)  NOT NULL, -- [FK] 방문할 구체적인 장소
    SCHEDULE_ID       VARCHAR2(20)  NOT NULL, -- [FK] 연결된 일정/게시물 아이디, 공통 fk라 따로 fk잡지 않았음 자바로 앞자리에 따라 입력 제한 처리를 하던해야함
    SCHEDULE_TYPE	  VARCHAR2(20)  NOT NULL,
    CONSTRAINT PK_VISIT_ITEM PRIMARY KEY (VISIT_ITEM_ID),
    CONSTRAINT FK_VISIT_PLACE FOREIGN KEY (PLACE_ID) REFERENCES PLACE(PLACE_ID)
);
DROP TABLE VISIT_ITEM

