-- 1. 사용자 정보 (USERS)
-- 서비스 이용자의 기본 정보를 저장합니다.
CREATE SEQUENCE SEQ_USERS;
DROP SEQUENCE SEQ_USERS;

CREATE TABLE USERS (
    USER_ID       VARCHAR2(20)  NOT NULL, -- [PK] 사용자 식별 ID
    EMAIL         VARCHAR2(200) NOT NULL, -- 사용자 이메일 (로그인/알림용)
    NAME          VARCHAR2(100) NOT NULL, -- 사용자 이름
    PASSWORD      VARCHAR2(200) NOT NULL, -- 암호화된 비밀번호
    CONSTRAINT PK_USERS PRIMARY KEY (USER_ID)
);
SELECT * FROM USERS;

-- 2. 장소 통합 관리 (PLACE)
-- 레저, 식당, 숙박의 공통 정보(이름, 위치 등)를 모아둔 '통합 인덱스'입니다.
CREATE SEQUENCE SEQ_PLACE;
DROP SEQUENCE SEQ_PLACE;

CREATE TABLE PLACE (
    PLACE_ID      VARCHAR2(20)  NOT NULL, -- [PK] 장소 고유 번호 (API 제공 ID)
    TITLE         VARCHAR2(200) NOT NULL, -- 장소 명칭
    ADDR1         VARCHAR2(500),          -- 도로명/지번 주소
    ADDR2         VARCHAR2(500),          -- 상세 주소 (동/호수 등)
    MAPX          VARCHAR2(100) NOT NULL, -- 경도 (X좌표)
    MAPY          VARCHAR2(100) NOT NULL, -- 위도 (Y좌표)
    FIRST_IMAGE   VARCHAR2(1000),         -- 대표 이미지 주소
    LIKE_COUNT    NUMBER(20)    DEFAULT 0,-- 좋아요 합계
    PLACE_TYPE    VARCHAR2(20)  NOT NULL, -- [Flag] 장소 구분 (LEISURE, RESTAURANT, STAY)
    LCLSSYSTM1    VARCHAR2(100),          -- 대분류 (예: 인문(문화/예술/역사))
    LCLSSYSTM2    VARCHAR2(100),          -- 중분류 (예: 문화시설)
    LCLSSYSTM3    VARCHAR2(100),          -- 소분류 (예: 박물관)
    CONSTRAINT PK_PLACE PRIMARY KEY (PLACE_ID)
);
DROP TABLE PLACE

SELECT * FROM PLACE;



