-- 6. 내 일정 (MY_SCHEDULE)
-- 사용자가 개인적으로 생성한 여행 일정입니다.
CREATE SEQUENCE SEQ_MY_SCHEDULE;
DROP SEQUENCE SEQ_MY_SCHEDULE;

CREATE TABLE MY_SCHEDULE (
    MY_SCHEDULE_ID    VARCHAR2(20)  NOT NULL, -- [PK] 일정 고유 아이디
    TITLE             VARCHAR2(200) NOT NULL, -- 일정 제목
    START_AT          DATE          NOT NULL, -- 여행 시작 날짜 및 시간
    BUDGET_DETAILS    VARCHAR2(200),          -- 여행 총 예산 메모
    TODO_DETAILS      VARCHAR2(200),          -- 여행 전 할 일 메모
    IS_SHARED         NUMBER(1)     DEFAULT 0,-- 공유 여부 (0:비공개, 1:공개)
    USER_ID           VARCHAR2(20)  NOT NULL, -- [FK] 일정을 소유한 사용자
    CONSTRAINT PK_MY_SCHEDULE PRIMARY KEY (MY_SCHEDULE_ID),
    CONSTRAINT FK_SCHEDULE_USER FOREIGN KEY (USER_ID) REFERENCES USERS(USER_ID)
);
DROP TABLE MY_SCHEDULE

